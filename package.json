{
  "name": "tarifist",
  "version": "0.1.0",
  "private": true,
  "description": "Open-source transit directions for Istanbul — rail, metro, and bus routing on a single map.",
  "license": "MIT",
  "author": {
    "name": "Berkay Çubuk",
    "url": "https://berkaycubuk.com"
  },
  "homepage": "https://tarif.ist",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/berkaycubuk/tarif.ist.git"
  },
  "bugs": {
    "url": "https://github.com/berkaycubuk/tarif.ist/issues"
  },
  "keywords": [
    "istanbul",
    "transit",
    "routing",
    "metro",
    "iett",
    "openstreetmap",
    "leaflet",
    "gtfs"
  ],
  "type": "module",
  "scripts": {
    "sync:data": "node scripts/sync-transit-data.mjs",
    "sync:gtfs": "node scripts/sync-gtfs.mjs",
    "sync:bus": "node scripts/sync-bus-data.mjs",
    "predev": "node scripts/ensure-data.mjs",
    "prebuild": "node scripts/ensure-data.mjs",
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.4",
    "@types/leaflet": "^1.9.21",
    "tailwindcss": "^4.2.4",
    "typescript": "~6.0.2",
    "vite": "^8.0.10",
    "vitest": "^4.1.6"
  },
  "dependencies": {
    "leaflet": "^1.9.4"
  }
}
